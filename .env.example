# Copy this file to .env for local development.
# Never commit .env — it's in .gitignore.

# ── Required for all profiles ─────────────────────────────────────────────────

# GCP project ID containing your BigQuery data
BIGQUERY_PROJECT=my-gcp-project

# BigQuery dataset name (default: analytics)
BIGQUERY_DATASET=analytics

# Full contents of your GCP service account JSON key
# Must have BigQuery Data Viewer + Job User roles, and Editor on your tracking sheet
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Gmail address and App Password used to send outreach emails
# App Passwords: https://myaccount.google.com/apppasswords (requires 2FA)
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Required for calendly capacity profiles ───────────────────────────────────

# Calendly personal access token
# Calendly → Account → Integrations → API & Webhooks
CALENDLY_API_KEY=eyJhbGciOiJIUzI1NiJ9...

# ── Optional ──────────────────────────────────────────────────────────────────

# Profile name to run (must match a key under `profiles:` in config.yml)
OUTREACH_PROFILE=interview_outreach

# Set to true to run the full flow without sending emails or writing to the sheet
DRY_RUN=false

# Send all batches to this single address instead of real users (skips dedup)
# Useful for previewing email formatting
TEST_EMAIL=

# Slack incoming webhook URL for failure alerts (optional)
SLACK_WEBHOOK_URL=

# ── Required for activecampaign outbound profiles only ────────────────────────

ACTIVECAMPAIGN_API_URL=https://youraccount.api-us1.com
ACTIVECAMPAIGN_API_KEY=your-ac-api-key
